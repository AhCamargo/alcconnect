                  "  const wh = pm.response.json().webhook;",
                  "  pm.expect(wh).to.have.property('id');",
                  "  pm.expect(wh.url).to.eql('https://webhook.site/test');",
                  "  pm.expect(wh.eventType).to.eql('incoming_call');",
                  "  pm.expect(wh.active).to.be.true;",
                  "});",
