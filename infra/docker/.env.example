# ========================================
# ALC Connect — Variáveis de ambiente
# Copie para .env e preencha com seus valores
# ========================================

# Postgres
POSTGRES_USER=alcconnect
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=alcconnect

# JWT
JWT_SECRET=TROQUE_POR_SEGREDO_FORTE

# SMTP (Resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_COLOQUE_SUA_API_KEY
SMTP_FROM=contato@seudominio.com.br
EMAIL_TO=contato@seudominio.com.br
