# Postgres
POSTGRES_USER=alcconnect
POSTGRES_PASSWORD=TROCAR_POR_SENHA_FORTE
POSTGRES_DB=alcconnect

# JWT
JWT_SECRET=TROCAR_POR_SEGREDO_FORTE_32_CHARS

# CORS (domínios separados por vírgula)
CORS_ORIGINS=https://app.alcconnect.com.br,https://alcconnect.com.br,https://www.alcconnect.com.br

# API URL para o Dashboard (usado no build)
VITE_API_URL=https://api.alcconnect.com.br

# SMTP (Resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=contato@alcconnect.com.br
EMAIL_TO=contato@alcconnect.com.br
