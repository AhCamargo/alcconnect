generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(uuid())
  name      String?
  email     String?
  ddd       String?
  usage     String?
  createdAt DateTime @default(now())
}

model Number {
  id          String   @id @default(uuid())
  phoneNumber String   @unique
  ddd         String
  region      String?
  type        String
  status      String
  monthlyPrice Float
  setupPrice  Float
  providerRef String?
  tenantId    String
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  activatedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebhookEvent {
  id        String @id @default(uuid())
  webhookId String
  payload   Json
  createdAt DateTime @default(now())
}

model Payment {
  id           String   @id @default(uuid())
  orderId      String?
  amount       Float?
  method       String?
  status       String
  webhookPayload Json?
  paidAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  document  String   @unique
  phone     String
  whatsapp  String
  role      String   @default("USER")
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  phoneNumbers Number[]
}
