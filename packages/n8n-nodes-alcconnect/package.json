{
  "name": "n8n-nodes-alcconnect",
  "version": "1.0.0",
  "description": "n8n community node for ALC Connect — virtual numbers, SMS, WhatsApp and automation.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "alcconnect",
    "sms",
    "whatsapp",
    "virtual-number",
    "pabx"
  ],
  "license": "MIT",
  "author": {
    "name": "ALC Connect",
    "email": "contato@alcconnect.com.br"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alcconnect/n8n-nodes-alcconnect"
  },
  "main": "dist/nodes/AlcConnect/AlcConnect.node.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AlcConnectApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AlcConnect/AlcConnect.node.js",
      "dist/nodes/AlcConnect/AlcConnectTrigger.node.js"
    ]
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
